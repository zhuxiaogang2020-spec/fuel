# Fuel2 后端环境变量
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fuel_db

# 微信小程序
WECHAT_APPID=wx5ebd4176b7e2eb8d
WECHAT_SECRET=your_wechat_secret_here

# 腾讯地图 API Key
TENCENT_MAP_KEY=your_tencent_map_key_here

# Google Maps API Key
GOOGLE_MAP_KEY=your_google_map_key_here

# 服务端口
PORT=3000

# 环境：development / production
NODE_ENV=development

# Mock 模式：无真实 API Key 时设为 true
USE_MOCK=true

# GasBuddy 油价接口（家庭 IP 上的 FastAPI 服务）
# GASBUDDY_API_URL=http://your-home-ip:8000
# GASBUDDY_API_ENABLED=true
# GASBUDDY_SEARCH_RADIUS=15
# GASBUDDY_API_TIMEOUT_MS=30000
